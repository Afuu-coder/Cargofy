# ============================================================
# Cargofy - Environment Variables
# FAR AWAY 2026 | Logistics + Agentic Systems
# ============================================================
# Copy to .env and fill in your values.
# NEVER commit .env to GitHub.
# ============================================================

# Core
DATABASE_URL=postgresql://user:password@localhost:5432/cargofy
SECRET_KEY=your-super-secret-jwt-key-min-32-chars
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# ── Google AI (REQUIRED for Autonomous Agent) ─────────────────────────────────
# Free API key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSy...

# ── Google Cloud (Optional - BigQuery + Pub/Sub + Vertex AI) ──────────────────
VERTEX_AI_PROJECT=your-gcp-project-id
VERTEX_AI_LOCATION=asia-south1
PUBSUB_PROJECT=your-gcp-project-id

# ── Firebase Realtime Database (Optional - live dashboard updates) ─────────────
# Free tier: https://console.firebase.google.com
FIREBASE_DB_URL=https://your-project-default-rtdb.firebaseio.com
FIREBASE_SERVICE_ACCOUNT_PATH=./secrets/firebase_service_account.json

# ── Google Maps API (Optional - haversine fallback used if missing) ────────────
# Free key: https://console.cloud.google.com/apis/library/maps-backend.googleapis.com
GOOGLE_MAPS_API_KEY=AIzaSy...

# ── Mapbox (Frontend 3D Map - Optional, demo works without it) ─────────────────
# Free key: https://account.mapbox.com
MAPBOX_API_KEY=pk.eyJ1...

# ── WhatsApp Alerts - CallMeBot (FREE - PRIMARY, no credit card) ───────────────
# Setup in 2 minutes:
#   1. Add +34 644 59 74 21 to your WhatsApp contacts
#   2. Send this message: "I allow callmebot to send me messages"
#   3. You receive your API key via WhatsApp
# Docs: https://www.callmebot.com/blog/free-api-whatsapp-messages/
CALLMEBOT_API_KEY=123456
CALLMEBOT_PHONE=+919876543210

# ── ULIP - India Govt APIs (Optional - mock works without keys) ────────────────
# Register: https://ulip.dpiit.gov.in
ULIP_API_KEY=
VAHAN_API_KEY=
SARATHI_API_KEY=

# ── Blockchain - Ethereum Sepolia Testnet (Optional - mock if not set) ─────────
# Free Sepolia RPC: https://www.alchemy.com (free tier)
# Free Sepolia ETH: https://sepoliafaucet.com
# Deploy contract: cd blockchain && npx hardhat run scripts/deploy.js --network sepolia
BLOCKCHAIN_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
BLOCKCHAIN_PRIVATE_KEY=0x...
BLOCKCHAIN_CONTRACT_ADDRESS=0x...

# ── Optional Services ──────────────────────────────────────────────────────────
OPENWEATHER_API_KEY=
REDIS_URL=redis://localhost:6379/0