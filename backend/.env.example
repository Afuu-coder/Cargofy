# ============================================================
# Cargofy — Environment Variables Template
# FAR AWAY 2026 Hackathon | Logistics & Transit
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to GitHub.
# ============================================================

# Core
DATABASE_URL=postgresql://user:password@localhost:5432/cargofy
SECRET_KEY=your-super-secret-jwt-key-change-this
BACKEND_URL=http://localhost:8000

# Google AI (REQUIRED for Autonomous Agent)
# Get free key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSy...

# Google Cloud (Optional)
VERTEX_AI_PROJECT=your-gcp-project-id
VERTEX_AI_LOCATION=us-central1

# Firebase (Optional - RTDB real-time)
FIREBASE_DB_URL=https://your-project-default-rtdb.firebaseio.com

# Google Maps (Optional - haversine fallback used if missing)
GOOGLE_MAPS_API_KEY=AIzaSy...

# CallMeBot FREE WhatsApp - Setup: https://www.callmebot.com
# 1. Add +34 644 59 74 21 on WhatsApp
# 2. Send: "I allow callmebot to send me messages"
# 3. You receive API key
CALLMEBOT_API_KEY=123456
CALLMEBOT_PHONE=+919876543210

# Twilio (fallback)
TWILIO_ACCOUNT_SID=ACxxxx
TWILIO_AUTH_TOKEN=xxxx
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Meta WhatsApp Business API
META_WA_PHONE_NUMBER_ID=
META_WA_ACCESS_TOKEN=
META_WA_WEBHOOK_VERIFY_TOKEN=cargofy-webhook-2026

# ULIP India Govt APIs (mock works without keys)
ULIP_CLIENT_ID=
ULIP_CLIENT_SECRET=

# Blockchain - Ethereum Sepolia Testnet
# Free RPC: https://www.alchemy.com
# Free ETH: https://sepoliafaucet.com
BLOCKCHAIN_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
BLOCKCHAIN_PRIVATE_KEY=0x...
BLOCKCHAIN_CONTRACT_ADDRESS=0x...

# Mapbox for frontend map
MAPBOX_API_KEY=pk.eyJ1...

# Optional
OPENWEATHER_API_KEY=
REDIS_URL=redis://localhost:6379/0
PUBSUB_PROJECT=your-gcp-project-id
